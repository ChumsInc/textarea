{
  "name": "@chumsinc/textarea",
  "version": "1.0.6-beta.0",
  "description": "An auto resizing textarea for React",
  "keywords": [
    "TextArea",
    "resize"
  ],
  "homepage": "https://github.com/ChumsInc/textarea#readme",
  "bugs": {
    "url": "https://github.com/ChumsInc/textarea/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChumsInc/textarea.git"
  },
  "license": "ISC",
  "author": "Steve Montgomery",
  "type": "module",
  "source": "./src/TextArea.tsx",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/TextArea.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/TextArea.d.ts",
        "default": "./dist/index.es.js"
      },
      "require": {
        "types": "./dist/TextArea.d.ts",
        "default": "./dist/index.cjs.js"
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build-vite && npm run build-dts",
    "build-vite": "vite build",
    "build-dts": "tsc -p tsconfig-build.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "version": "auto-changelog -p && git add CHANGELOG.md"
  },
  "peerDependencies": {
    "@emotion/styled": "^11.14.0",
    "classnames": "*",
    "react": ">=18.1.0",
    "react-dom": ">=18.1.0"
  },
  "devDependencies": {
    "@emotion/styled": "^11.14.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "auto-changelog": "^2.4.0",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^8.0.6"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "auto-changelog": {
    "template": "changelog-template.hbs",
    "unreleased": true,
    "commitLimit": false,
    "breakingPattern": "BREAKING CHANGE:"
  }
}
